#!/usr/bin/env python3
from __future__ import annotations

import json
import os
import re
import sys
import tomllib
import time
from pathlib import Path
from urllib.parse import quote, urlsplit, urlunsplit


REASONING_EFFORT_VALUES = {"minimal", "low", "medium", "high", "xhigh"}
MODEL_VERBOSITY_VALUES = {"low", "medium", "high"}
MODEL_RE = re.compile(r"^[A-Za-z0-9_.:/-]+$")
BARE_KEY_RE = re.compile(r"^[A-Za-z0-9_-]+$")
PROFILE_NAME = "litellm"
MANAGED_HOME_NAME = ".codex-headroom"
LOCAL_BACKUP_TAG = "codex-headroom-local-backup"
SENSITIVE_TOP_LEVEL_KEYS = {
    "api_key",
    "auth_token",
    "openai_api_key",
    "password",
    "secret",
    "token",
}


def die(message: str, code: int = 1) -> None:
    print(f"codex-litellm: {message}", file=sys.stderr)
    raise SystemExit(code)


def repo_root() -> Path:
    return Path(__file__).resolve().parents[1]


def load_dotenv(path: Path) -> None:
    if not path.exists():
        return
    for raw_line in path.read_text(encoding="utf-8").splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#"):
            continue
        if line.startswith("export "):
            line = line[len("export ") :].strip()
        if "=" not in line:
            continue
        key, value = line.split("=", 1)
        key = key.strip()
        value = value.strip()
        if not key or key in os.environ:
            continue
        if (
            len(value) >= 2
            and value[0] == value[-1]
            and value[0] in {"'", '"'}
        ):
            value = value[1:-1]
        os.environ[key] = value


def needs_api_key(argv: list[str]) -> bool:
    return not any(arg in {"-h", "--help", "help", "-V", "--version", "completion"} for arg in argv)


def truthy_env(name: str, default: bool) -> bool:
    raw = os.environ.get(name)
    if raw is None:
        return default
    return raw in {"1", "true", "TRUE", "yes", "YES", "on", "ON"}


def normalize_base_url(raw: str, *, env_name: str, suffix: str) -> str:
    parts = urlsplit(raw.strip())
    if (
        parts.scheme not in {"http", "https"}
        or not parts.netloc
        or parts.username
        or parts.password
        or parts.query
        or parts.fragment
    ):
        die(f"{env_name} must be an http(s) URL without credentials, query, or fragment.")
    path = parts.path.rstrip("/")
    if not path:
        path = suffix
    elif not path.endswith(suffix):
        path = f"{path}{suffix}"
    if suffix == "/mcp":
        path = f"{path}/"
    return urlunsplit((parts.scheme, parts.netloc, path, "", ""))


def project_name_from_cwd() -> str:
    name = Path.cwd().name.strip()
    return quote(name, safe="-_.() ") if name else ""


def default_managed_home() -> Path:
    home = os.environ.get("HOME")
    if home:
        return Path(home).expanduser() / MANAGED_HOME_NAME
    return repo_root() / "tmp" / "codex-headroom-home"


def default_native_home() -> Path:
    home = os.environ.get("HOME")
    if home:
        return Path(home).expanduser() / ".codex"
    return repo_root() / "tmp" / "missing-native-codex-home"


def validate_model(model: str) -> str:
    if not model or not MODEL_RE.match(model):
        die("CODEX_LITELLM_MODEL contains unsupported characters.")
    return model


def load_native_config(path: Path) -> dict[str, object]:
    try:
        data = tomllib.loads(path.read_text(encoding="utf-8"))
    except (OSError, tomllib.TOMLDecodeError):
        return {}
    return data if isinstance(data, dict) else {}


def toml_key(key: str) -> str:
    if BARE_KEY_RE.match(key):
        return key
    return json.dumps(key)


def toml_value(value: object) -> str:
    if isinstance(value, bool):
        return "true" if value else "false"
    if isinstance(value, int) and not isinstance(value, bool):
        return str(value)
    if isinstance(value, float):
        return repr(value)
    if isinstance(value, str):
        return json.dumps(value)
    if isinstance(value, list):
        return "[" + ", ".join(toml_value(item) for item in value) + "]"
    die(f"cannot render TOML value of type {type(value).__name__}")


def render_toml(data: dict[str, object]) -> str:
    lines: list[str] = ["# Generated by bin/codex-litellm. Keep this file free of secrets."]

    def write_table(table: dict[str, object], path: list[str]) -> None:
        scalars: list[tuple[str, object]] = []
        nested: list[tuple[str, dict[str, object]]] = []
        for key in sorted(table):
            value = table[key]
            if isinstance(value, dict):
                nested.append((key, value))
            else:
                scalars.append((key, value))

        if path:
            lines.append("")
            lines.append("[" + ".".join(toml_key(part) for part in path) + "]")
        for key, value in scalars:
            lines.append(f"{toml_key(key)} = {toml_value(value)}")
        for key, value in nested:
            write_table(value, [*path, key])

    write_table(data, [])
    return "\n".join(lines).rstrip() + "\n"


def litellm_provider(base_url: str) -> dict[str, object]:
    return {
        "name": "Local LiteLLM",
        "base_url": base_url,
        "env_key": "OPENAI_API_KEY",
        "wire_api": "responses",
        "env_http_headers": {
            "X-LiteLLM-Proxy-Client": "CODEX_LITELLM_CLIENT",
            "X-LiteLLM-Proxy-Project": "CODEX_LITELLM_PROJECT",
            "X-LiteLLM-Proxy-Run": "LITELLM_PROXY_RUN_MARKER",
        },
    }


def resolved_model_settings(native_config: dict[str, object]) -> tuple[str, str, str]:
    native_model = native_config.get("model") if isinstance(native_config.get("model"), str) else ""
    if not native_model or not MODEL_RE.match(native_model):
        native_model = "gpt-5.5"
    model = validate_model(os.environ.get("CODEX_LITELLM_MODEL", native_model))

    native_effort = native_config.get("model_reasoning_effort")
    if native_effort not in REASONING_EFFORT_VALUES:
        native_effort = ""
    effort = os.environ.get("CODEX_LITELLM_REASONING_EFFORT", str(native_effort or ""))
    if effort not in {"", *REASONING_EFFORT_VALUES}:
        die("CODEX_LITELLM_REASONING_EFFORT must be one of minimal, low, medium, high, or xhigh.")

    native_verbosity = native_config.get("model_verbosity")
    if native_verbosity not in MODEL_VERBOSITY_VALUES:
        native_verbosity = ""
    verbosity = os.environ.get("CODEX_LITELLM_MODEL_VERBOSITY", str(native_verbosity or ""))
    if verbosity not in {"", *MODEL_VERBOSITY_VALUES}:
        die("CODEX_LITELLM_MODEL_VERBOSITY must be one of low, medium, or high.")

    return model, effort, verbosity


def managed_config(
    *,
    native_config: dict[str, object],
    inherit_native_config: bool,
    litellm_base_url: str,
    analytics_mcp_url: str,
) -> tuple[dict[str, object], dict[str, object]]:
    data: dict[str, object] = dict(native_config) if inherit_native_config else {}
    for key in SENSITIVE_TOP_LEVEL_KEYS:
        data.pop(key, None)

    model, effort, verbosity = resolved_model_settings(native_config if inherit_native_config else {})
    data["model"] = model
    if effort:
        data["model_reasoning_effort"] = effort
    else:
        data.pop("model_reasoning_effort", None)
    if verbosity:
        data["model_verbosity"] = verbosity
    else:
        data.pop("model_verbosity", None)

    data["model_provider"] = PROFILE_NAME
    data["openai_base_url"] = litellm_base_url

    providers = dict(data.get("model_providers") or {})
    providers.pop("headroom", None)
    providers[PROFILE_NAME] = litellm_provider(litellm_base_url)
    data["model_providers"] = providers

    mcp_servers = dict(data.get("mcp_servers") or {})
    mcp_servers.pop("headroom", None)
    mcp_servers.pop("headroom_memory", None)
    mcp_servers["analytics"] = {
        "url": analytics_mcp_url,
        "enabled": True,
    }
    data["mcp_servers"] = mcp_servers

    profile = {
        "model": model,
        "model_provider": PROFILE_NAME,
        "openai_base_url": litellm_base_url,
        "model_providers": {PROFILE_NAME: litellm_provider(litellm_base_url)},
    }
    if effort:
        profile["model_reasoning_effort"] = effort
    if verbosity:
        profile["model_verbosity"] = verbosity
    return data, profile


def sync_native_state(native_home: Path, managed_home: Path) -> None:
    if not native_home.exists():
        return
    for source in native_home.iterdir():
        if source.name in {"config.toml", f"{PROFILE_NAME}.config.toml"}:
            continue
        if source.name.endswith(".headroom-backup"):
            continue
        destination = managed_home / source.name
        if destination.is_symlink():
            if destination.resolve(strict=False) == source.resolve(strict=False):
                continue
            destination.unlink()
        elif destination.exists():
            backup = managed_home / (
                f".{source.name}.{LOCAL_BACKUP_TAG}.{int(time.time())}.{os.getpid()}"
            )
            destination.rename(backup)
        destination.symlink_to(source, target_is_directory=source.is_dir())


def find_real_codex() -> str:
    self_path = Path(__file__).resolve()
    candidates: list[str] = []
    for path_dir in os.get_exec_path():
        candidate = Path(path_dir) / "codex"
        if candidate.exists() and os.access(candidate, os.X_OK):
            resolved = candidate.resolve()
            if resolved != self_path and str(resolved) not in candidates:
                candidates.append(str(candidate))
    if not candidates:
        die("could not find a codex binary on PATH other than this wrapper.", code=127)
    return candidates[0]


def parse_profile_arg(argv: list[str]) -> tuple[bool, str]:
    expect_value = False
    for arg in argv:
        if expect_value:
            return True, arg
        if arg in {"-p", "--profile"}:
            expect_value = True
            continue
        if arg.startswith("--profile="):
            return True, arg.split("=", 1)[1]
    if expect_value:
        die(f"--profile requires a value; use --profile {PROFILE_NAME} or omit it.")
    return False, ""


def main(argv: list[str]) -> int:
    root = repo_root()
    load_dotenv(root / ".env")

    if os.environ.get("LITELLM_MASTER_KEY"):
        os.environ["OPENAI_API_KEY"] = os.environ["LITELLM_MASTER_KEY"]
    elif needs_api_key(argv):
        die(f"LITELLM_MASTER_KEY is not set; add it to {root / '.env'} or the environment.")

    litellm_base_url = normalize_base_url(
        os.environ.get("CODEX_LITELLM_BASE_URL", "http://127.0.0.1:4000"),
        env_name="CODEX_LITELLM_BASE_URL",
        suffix="/v1",
    )
    analytics_mcp_url = normalize_base_url(
        os.environ.get("CODEX_LITELLM_ANALYTICS_URL", "http://127.0.0.1:8010"),
        env_name="CODEX_LITELLM_ANALYTICS_URL",
        suffix="/mcp",
    )
    os.environ["OPENAI_BASE_URL"] = litellm_base_url

    os.environ.setdefault("CODEX_LITELLM_CLIENT", "codex")
    if "CODEX_LITELLM_PROJECT" not in os.environ:
        project = project_name_from_cwd()
        if project:
            os.environ["CODEX_LITELLM_PROJECT"] = project

    native_home = Path(os.environ.get("CODEX_LITELLM_NATIVE_HOME", default_native_home())).expanduser()
    managed_home = Path(os.environ.get("CODEX_LITELLM_HOME", default_managed_home())).expanduser()
    profile_seen, profile_value = parse_profile_arg(argv)
    if (
        profile_seen
        and profile_value != PROFILE_NAME
        and os.environ.get("CODEX_LITELLM_ALLOW_PROFILE_OVERRIDE") != "1"
    ):
        die(
            f"refusing --profile {profile_value} because it can bypass the managed LiteLLM provider; "
            f"use --profile {PROFILE_NAME}, omit --profile, or set CODEX_LITELLM_ALLOW_PROFILE_OVERRIDE=1."
        )

    if (
        managed_home.resolve(strict=False) == native_home.resolve(strict=False)
        and os.environ.get("CODEX_LITELLM_ALLOW_SHARED_HOME") != "1"
    ):
        die(
            "CODEX_LITELLM_HOME resolves to the native Codex home "
            f"({native_home}); choose a managed directory or set CODEX_LITELLM_ALLOW_SHARED_HOME=1."
        )
    managed_home.mkdir(parents=True, exist_ok=True)

    native_config_path = Path(
        os.environ.get("CODEX_LITELLM_NATIVE_CONFIG", native_home / "config.toml")
    ).expanduser()
    inherit_native_config = truthy_env("CODEX_LITELLM_INHERIT_NATIVE_CONFIG", True)
    native_config = load_native_config(native_config_path) if inherit_native_config else {}
    base_config, profile_config = managed_config(
        native_config=native_config,
        inherit_native_config=inherit_native_config,
        litellm_base_url=litellm_base_url,
        analytics_mcp_url=analytics_mcp_url,
    )
    (managed_home / "config.toml").write_text(render_toml(base_config), encoding="utf-8")
    (managed_home / f"{PROFILE_NAME}.config.toml").write_text(
        render_toml(profile_config),
        encoding="utf-8",
    )

    if truthy_env("CODEX_LITELLM_LINK_NATIVE_STATE", True):
        sync_native_state(native_home, managed_home)

    env = os.environ.copy()
    env["CODEX_HOME"] = str(managed_home)
    real_codex = find_real_codex()
    os.execvpe(real_codex, [real_codex, *argv], env)
    return 127


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
