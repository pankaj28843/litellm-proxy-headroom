# Local defaults. Copy to .env for Docker Compose overrides.
# Do not put real ChatGPT OAuth tokens in this file.
LITELLM_HEADROOM_HOST=127.0.0.1
LITELLM_HEADROOM_PORT=4000
LITELLM_HEADROOM_CONFIG=config/litellm.yaml

# LiteLLM/Open WebUI local auth. Replace before sharing a network.
LITELLM_MASTER_KEY=sk-local-change-me
CHATGPT_AUTH_FILE=auth.json

# Phoenix persistence.
PHOENIX_DB_PASSWORD=phoenix-local-change-me
PHOENIX_DEFAULT_RETENTION_POLICY_DAYS=90
PHOENIX_PROJECT_NAME=litellm-proxy-headroom

# Open WebUI bootstrap auth and signed cookies.
WEBUI_SECRET_KEY=open-webui-local-change-me
WEBUI_ADMIN_EMAIL=admin@example.local
WEBUI_ADMIN_PASSWORD=admin-local-change-me
WEBUI_ADMIN_NAME=Admin
