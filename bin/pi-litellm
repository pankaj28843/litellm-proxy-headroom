#!/usr/bin/env python3
from __future__ import annotations

import json
import os
import re
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parents[1]
SRC_ROOT = REPO_ROOT / "src"
if SRC_ROOT.exists():
    sys.path.insert(0, str(SRC_ROOT))

from litellm_proxy_headroom.agent_cli.managed_home import (  # noqa: E402
    PREFERENCES_FILE_NAME,
    compression_mode_header_value,
    default_home_path,
    find_real_executable,
    load_dotenv,
    load_preferences,
    normalize_base_url,
    preference_value,
    project_name_from_cwd,
    sync_native_state,
    truthy_env,
    write_preferences,
)

MANAGED_HOME_NAME = ".pi-headroom"
LOCAL_BACKUP_TAG = "pi-headroom-local-backup"
PROVIDER_ID = "litellm"
MODEL_RE = re.compile(r"^[A-Za-z0-9_.:/-]+$")
THINKING_VALUES = {"off", "minimal", "low", "medium", "high", "xhigh"}
NO_MODEL_COMMANDS = {
    "-h",
    "--help",
    "-v",
    "--version",
    "help",
    "install",
    "remove",
    "uninstall",
    "update",
    "list",
    "config",
}


def die(message: str, code: int = 1) -> None:
    print(f"pi-litellm: {message}", file=sys.stderr)
    raise SystemExit(code)


def default_managed_home() -> Path:
    return default_home_path(
        MANAGED_HOME_NAME,
        fallback=REPO_ROOT / "tmp" / "pi-headroom-home",
    )


def default_native_home() -> Path:
    return default_home_path(
        ".pi/agent",
        fallback=REPO_ROOT / "tmp" / "missing-native-pi-home",
    )


def managed_home() -> Path:
    raw = os.environ.get("PI_LITELLM_HOME")
    if raw:
        return Path(raw).expanduser()
    return default_managed_home()


def needs_api_key(argv: list[str]) -> bool:
    return not any(arg in NO_MODEL_COMMANDS for arg in argv)


def validate_model(model: str, *, env_name: str) -> str:
    if not model or not MODEL_RE.match(model):
        die(f"{env_name} contains unsupported characters.")
    return model


def option_value(argv: list[str], *names: str) -> str | None:
    expect_value = False
    for arg in argv:
        if expect_value:
            return arg
        if arg in names:
            expect_value = True
            continue
        for name in names:
            if arg.startswith(f"{name}="):
                return arg.split("=", 1)[1]
    if expect_value:
        die(f"{names[0]} requires a value.")
    return None


def has_model_arg(argv: list[str]) -> bool:
    return option_value(argv, "--model") is not None


def has_thinking_arg(argv: list[str]) -> bool:
    return option_value(argv, "--thinking") is not None


def has_provider_arg(argv: list[str]) -> bool:
    return option_value(argv, "--provider") is not None


def first_command(argv: list[str]) -> str:
    expect_value_for = {"--provider", "--model", "--api-key", "--mode", "--session"}
    skip_next = False
    for arg in argv:
        if skip_next:
            skip_next = False
            continue
        if arg in expect_value_for:
            skip_next = True
            continue
        if arg.startswith("-"):
            continue
        return arg
    return ""


def should_add_model_args(argv: list[str]) -> bool:
    if any(arg in NO_MODEL_COMMANDS for arg in argv):
        return False
    return first_command(argv) not in NO_MODEL_COMMANDS


def model_from_arg(argv: list[str]) -> str | None:
    value = option_value(argv, "--model")
    if not value:
        return None
    if value.startswith(f"{PROVIDER_ID}/"):
        return value.split("/", 1)[1]
    return value


def resolved_preferences(
    argv: list[str], preferences: dict[str, str], *, dotenv_keys: set[str]
) -> dict[str, str]:
    model = validate_model(
        preference_value(
            cli_value=model_from_arg(argv),
            env_name="PI_LITELLM_MODEL",
            preference_key="model",
            preferences=preferences,
            dotenv_keys=dotenv_keys,
            default="gpt-5.5",
        ),
        env_name="PI_LITELLM_MODEL",
    )
    small_model = validate_model(
        preference_value(
            env_name="PI_LITELLM_SMALL_MODEL",
            preference_key="small_model",
            preferences=preferences,
            dotenv_keys=dotenv_keys,
            default="gpt-5.5",
        ),
        env_name="PI_LITELLM_SMALL_MODEL",
    )
    thinking = preference_value(
        cli_value=option_value(argv, "--thinking"),
        env_name="PI_LITELLM_THINKING",
        preference_key="thinking",
        preferences=preferences,
        dotenv_keys=dotenv_keys,
        default="xhigh",
    )
    if thinking not in THINKING_VALUES:
        die(
            "PI_LITELLM_THINKING must be one of off, minimal, low, medium, high, or xhigh."
        )
    return {
        **preferences,
        "model": model,
        "small_model": small_model,
        "thinking": thinking,
    }


def model_entry(model: str) -> dict[str, object]:
    return {
        "id": model,
        "name": model,
        "reasoning": True,
        "input": ["text"],
        "contextWindow": 400000,
        "maxTokens": 128000,
        "compat": {
            "sendSessionIdHeader": False,
        },
    }


def models_config(
    model: str,
    small_model: str,
    *,
    base_url: str,
    compression_mode: str | None,
) -> dict[str, object]:
    models = [model_entry(model)]
    if small_model != model:
        models.append(model_entry(small_model))
    headers = {
        "X-LLM-Proxy-Client": "$PI_LITELLM_CLIENT",
        "X-LLM-Proxy-Project": "$PI_LITELLM_PROJECT",
        "X-LLM-Proxy-Run": "$LITELLM_PROXY_RUN_MARKER",
    }
    if compression_mode:
        headers["X-LLM-Proxy-Compression"] = "$PI_LITELLM_COMPRESSION_MODE"
    return {
        "providers": {
            PROVIDER_ID: {
                "baseUrl": base_url,
                "api": os.environ.get("PI_LITELLM_API", "openai-responses"),
                "apiKey": "$LITELLM_MASTER_KEY",
                "headers": headers,
                "models": models,
            }
        }
    }


def write_config(path: Path, data: dict[str, object]) -> None:
    path.write_text(
        json.dumps(data, indent=2, sort_keys=True) + "\n",
        encoding="utf-8",
    )


def real_pi() -> str:
    try:
        return find_real_executable(binary_name="pi", wrapper_path=Path(__file__))
    except FileNotFoundError:
        die("could not find a pi binary on PATH other than this wrapper.", code=127)


def default_extra_args(argv: list[str], *, model: str, thinking: str) -> list[str]:
    if not should_add_model_args(argv):
        return []
    provider = option_value(argv, "--provider")
    if provider and provider != PROVIDER_ID:
        if os.environ.get("PI_LITELLM_ALLOW_PROVIDER_OVERRIDE") == "1":
            return []
        die(
            "refusing to use a non-LiteLLM provider in pi-litellm; "
            "set PI_LITELLM_ALLOW_PROVIDER_OVERRIDE=1 only for deliberate debugging."
        )
    extra_args: list[str] = []
    if not has_provider_arg(argv) and not (
        (existing_model := option_value(argv, "--model")) and "/" in existing_model
    ):
        extra_args.extend(["--provider", PROVIDER_ID])
    if not has_model_arg(argv):
        extra_args.extend(["--model", model])
    if thinking and not has_thinking_arg(argv):
        extra_args.extend(["--thinking", thinking])
    return extra_args


def main(argv: list[str]) -> int:
    dotenv_keys = load_dotenv(REPO_ROOT / ".env")

    try:
        litellm_base_url = normalize_base_url(
            os.environ.get("PI_LITELLM_BASE_URL", "http://10.20.30.1:24040"),
            env_name="PI_LITELLM_BASE_URL",
            suffix="/v1",
        )
    except ValueError as exc:
        die(str(exc))
    try:
        compression_mode = compression_mode_header_value(
            os.environ.get("PI_LITELLM_COMPRESSION_MODE"),
            env_name="PI_LITELLM_COMPRESSION_MODE",
        )
    except ValueError as exc:
        die(str(exc))
    if compression_mode is None:
        os.environ.pop("PI_LITELLM_COMPRESSION_MODE", None)
    else:
        os.environ["PI_LITELLM_COMPRESSION_MODE"] = compression_mode

    if not os.environ.get("LITELLM_MASTER_KEY") and needs_api_key(argv):
        die(
            f"LITELLM_MASTER_KEY is not set; add it to {REPO_ROOT / '.env'} or the environment."
        )

    home = managed_home()
    home.mkdir(parents=True, exist_ok=True)
    native_home = Path(os.environ.get("PI_LITELLM_NATIVE_HOME", default_native_home()))
    native_home = native_home.expanduser()
    if truthy_env("PI_LITELLM_LINK_NATIVE_STATE", True):
        sync_native_state(
            native_home=native_home,
            managed_home=home,
            excluded_names={
                "config.json",
                "models.json",
                "settings.json",
                "settings.local.json",
                PREFERENCES_FILE_NAME,
            },
            excluded_globs=("*.config.*", "settings*.json"),
            backup_tag=LOCAL_BACKUP_TAG,
        )
    preferences = resolved_preferences(
        argv, load_preferences(home), dotenv_keys=dotenv_keys
    )
    write_preferences(home, preferences)
    model = preferences["model"]
    small_model = preferences["small_model"]
    thinking = preferences["thinking"]
    write_config(
        home / "models.json",
        models_config(
            model,
            small_model,
            base_url=litellm_base_url,
            compression_mode=compression_mode,
        ),
    )

    os.environ["PI_CODING_AGENT_DIR"] = str(home)
    os.environ.setdefault("PI_LITELLM_CLIENT", "pi")
    if "PI_LITELLM_PROJECT" not in os.environ:
        project = project_name_from_cwd()
        if project:
            os.environ["PI_LITELLM_PROJECT"] = project

    executable = real_pi()
    os.execvpe(
        executable,
        [executable, *default_extra_args(argv, model=model, thinking=thinking), *argv],
        os.environ.copy(),
    )
    return 127


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
