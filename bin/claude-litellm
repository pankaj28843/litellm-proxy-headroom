#!/usr/bin/env python3
from __future__ import annotations

import json
import os
import shutil
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parents[1]
SRC_ROOT = REPO_ROOT / "src"
if SRC_ROOT.exists():
    sys.path.insert(0, str(SRC_ROOT))

from litellm_proxy_headroom.agent_cli.managed_home import (  # noqa: E402
    PREFERENCES_FILE_NAME,
    compression_mode_header_value,
    default_home_path,
    find_real_executable,
    load_dotenv,
    load_preferences,
    normalize_base_url,
    option_value,
    preference_value,
    project_name_from_cwd,
    sync_native_state,
    truthy_env,
    write_preferences,
)

MANAGED_HOME_NAME = ".claude-headroom"
LOCAL_BACKUP_TAG = "claude-headroom-local-backup"
EFFORT_VALUES = {"low", "medium", "high", "xhigh", "max"}
MANAGED_CONFIG_NAMES = {
    ".config",
    "backups",
    "bin",
    "cache",
    "config.json",
    "settings.json",
    "settings.local.json",
}
PERMISSION_MODE_VALUES = {
    "acceptEdits",
    "auto",
    "bypassPermissions",
    "default",
    "dontAsk",
    "plan",
}


def die(message: str, code: int = 1) -> None:
    print(f"claude-litellm: {message}", file=sys.stderr)
    raise SystemExit(code)


def needs_api_key(argv: list[str]) -> bool:
    return not any(arg in {"-h", "--help", "help", "-v", "--version"} for arg in argv)


def default_managed_home() -> Path:
    return default_home_path(
        MANAGED_HOME_NAME,
        fallback=REPO_ROOT / "tmp" / "claude-headroom-home",
    )


def default_native_home() -> Path:
    return default_home_path(
        ".claude",
        fallback=REPO_ROOT / "tmp" / "missing-native-claude-home",
    )


def managed_home() -> Path:
    raw = os.environ.get("CLAUDE_LITELLM_HOME") or os.environ.get(
        "CLAUDE_LITELLM_STATE_DIR"
    )
    if raw:
        return Path(raw).expanduser()
    return default_managed_home()


def has_option(argv: list[str], *names: str) -> bool:
    return any(
        arg in names or any(arg.startswith(f"{name}=") for name in names)
        for arg in argv
    )


def resolve_preference(
    *,
    argv: list[str],
    env_name: str,
    preference_key: str,
    option_names: tuple[str, ...],
    preferences: dict[str, str],
    dotenv_keys: set[str],
    default: str = "",
    allowed_values: set[str] | None = None,
) -> str:
    value = preference_value(
        cli_value=option_value(argv, *option_names),
        env_name=env_name,
        preference_key=preference_key,
        preferences=preferences,
        dotenv_keys=dotenv_keys,
        default=default,
    )
    if value and allowed_values is not None and value not in allowed_values:
        die(f"{env_name} must be one of {', '.join(sorted(allowed_values))}.")
    return value


def write_mcp_config(path: Path, *, analytics_mcp_url: str) -> None:
    payload = {
        "mcpServers": {
            "analytics": {
                "type": "http",
                "url": analytics_mcp_url,
            }
        }
    }
    path.write_text(
        json.dumps(payload, indent=2, sort_keys=True) + "\n", encoding="utf-8"
    )


def header_value(value: str | None) -> str | None:
    if value is None:
        return None
    cleaned = value.replace("\r", " ").replace("\n", " ").strip()
    return cleaned or None


def merge_custom_headers(
    *,
    client: str,
    project: str | None,
    marker: str | None,
    compression_mode: str | None,
) -> None:
    headers: list[str] = []
    existing = os.environ.get("ANTHROPIC_CUSTOM_HEADERS")
    if existing:
        headers.extend(line for line in existing.splitlines() if line.strip())
    cleaned_client = header_value(client) or "claude"
    cleaned_project = header_value(project)
    cleaned_marker = header_value(marker)
    headers.append(f"X-LLM-Proxy-Client: {cleaned_client}")
    if cleaned_project:
        headers.append(f"X-LLM-Proxy-Project: {cleaned_project}")
    if cleaned_marker:
        headers.append(f"X-LLM-Proxy-Run: {cleaned_marker}")
    if compression_mode:
        headers.append(f"X-LLM-Proxy-Compression: {compression_mode}")
    os.environ["ANTHROPIC_CUSTOM_HEADERS"] = "\n".join(headers)


def real_claude() -> str:
    try:
        return find_real_executable(binary_name="claude", wrapper_path=Path(__file__))
    except FileNotFoundError:
        die("could not find a claude binary on PATH other than this wrapper.", code=127)


def write_managed_top_level_config(home: Path, *, preferences: dict[str, str]) -> None:
    target = home / ".claude.json"
    if target.is_symlink():
        target.unlink()
    elif target.exists() and not target.is_file():
        die(f"{target} must be a file or symlink.")
    payload = {
        "hasCompletedOnboarding": True,
        "litellmProxy": {
            "backend_model": "gpt-5.5",
            "effort": preferences.get("effort", "xhigh"),
            "model": preferences.get("model", "sonnet"),
            "reasoning_effort": preferences.get("effort", "xhigh"),
        },
        "projects": {},
    }
    tmp_path = target.with_suffix(f"{target.suffix}.{os.getpid()}.tmp")
    tmp_path.write_text(
        json.dumps(payload, indent=2, sort_keys=True) + "\n",
        encoding="utf-8",
    )
    tmp_path.replace(target)


def remove_managed_path(path: Path) -> None:
    if path.is_symlink() or path.is_file():
        path.unlink()
    elif path.is_dir():
        shutil.rmtree(path)


def remove_stale_managed_config(home: Path) -> None:
    for name in MANAGED_CONFIG_NAMES:
        remove_managed_path(home / name)
    for child in list(home.iterdir()):
        if (
            child.name.startswith("settings") and ".json" in child.name
        ) or ".config." in child.name:
            remove_managed_path(child)


def resolved_preferences(
    argv: list[str], preferences: dict[str, str], *, dotenv_keys: set[str]
) -> dict[str, str]:
    return {
        **preferences,
        "model": resolve_preference(
            argv=argv,
            env_name="CLAUDE_LITELLM_MODEL",
            preference_key="model",
            option_names=("--model",),
            preferences=preferences,
            dotenv_keys=dotenv_keys,
            default="sonnet",
        ),
        "effort": resolve_preference(
            argv=argv,
            env_name="CLAUDE_LITELLM_EFFORT",
            preference_key="effort",
            option_names=("--effort",),
            preferences=preferences,
            dotenv_keys=dotenv_keys,
            default="xhigh",
            allowed_values=EFFORT_VALUES,
        ),
        "permission_mode": resolve_preference(
            argv=argv,
            env_name="CLAUDE_LITELLM_PERMISSION_MODE",
            preference_key="permission_mode",
            option_names=("--permission-mode",),
            preferences=preferences,
            dotenv_keys=dotenv_keys,
            allowed_values=PERMISSION_MODE_VALUES,
        ),
    }


def default_extra_args(
    argv: list[str], *, mcp_config: Path | None, preferences: dict[str, str]
) -> list[str]:
    extra_args: list[str] = []
    if not has_option(argv, "--setting-sources"):
        extra_args.extend(
            [
                "--setting-sources",
                os.environ.get("CLAUDE_LITELLM_SETTING_SOURCES", ""),
            ]
        )
    if mcp_config is not None and not has_option(argv, "--mcp-config"):
        extra_args.extend(["--mcp-config", str(mcp_config)])
        if truthy_env("CLAUDE_LITELLM_STRICT_MCP", True):
            extra_args.append("--strict-mcp-config")
    if mcp_config is not None and not has_option(
        argv, "--allowedTools", "--allowed-tools"
    ):
        extra_args.extend(
            [
                "--allowedTools",
                os.environ.get("CLAUDE_LITELLM_ALLOWED_TOOLS", "mcp__analytics__*"),
            ]
        )
    if not has_option(argv, "--model"):
        extra_args.extend(["--model", preferences.get("model", "sonnet")])
    if preferences.get("effort") and not has_option(argv, "--effort"):
        extra_args.extend(["--effort", preferences["effort"]])
    if preferences.get("permission_mode") and not has_option(argv, "--permission-mode"):
        extra_args.extend(["--permission-mode", preferences["permission_mode"]])
    return extra_args


def main(argv: list[str]) -> int:
    dotenv_keys = load_dotenv(REPO_ROOT / ".env")

    if os.environ.get("LITELLM_MASTER_KEY"):
        os.environ["ANTHROPIC_AUTH_TOKEN"] = os.environ["LITELLM_MASTER_KEY"]
        os.environ.pop("ANTHROPIC_API_KEY", None)
    elif needs_api_key(argv):
        die(
            f"LITELLM_MASTER_KEY is not set; add it to {REPO_ROOT / '.env'} or the environment."
        )

    try:
        anthropic_base_url = normalize_base_url(
            os.environ.get("CLAUDE_LITELLM_BASE_URL", "http://10.20.30.1:24040"),
            env_name="CLAUDE_LITELLM_BASE_URL",
            suffix="",
        )
        analytics_mcp_url = (
            None
            if truthy_env("CLAUDE_LITELLM_DISABLE_ANALYTICS_MCP", False)
            else normalize_base_url(
                os.environ.get(
                    "CLAUDE_LITELLM_ANALYTICS_URL", "http://127.0.0.1:28010"
                ),
                env_name="CLAUDE_LITELLM_ANALYTICS_URL",
                suffix="/mcp",
            )
        )
    except ValueError as exc:
        die(str(exc))
    try:
        compression_mode = compression_mode_header_value(
            os.environ.get("CLAUDE_LITELLM_COMPRESSION_MODE"),
            env_name="CLAUDE_LITELLM_COMPRESSION_MODE",
        )
    except ValueError as exc:
        die(str(exc))
    if compression_mode is None:
        os.environ.pop("CLAUDE_LITELLM_COMPRESSION_MODE", None)
    else:
        os.environ["CLAUDE_LITELLM_COMPRESSION_MODE"] = compression_mode

    os.environ["ANTHROPIC_BASE_URL"] = anthropic_base_url
    os.environ.setdefault("CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY", "1")
    client = os.environ.get("CLAUDE_LITELLM_CLIENT", "claude")
    project = os.environ.get("CLAUDE_LITELLM_PROJECT") or project_name_from_cwd()
    merge_custom_headers(
        client=client,
        project=project,
        marker=os.environ.get("LITELLM_PROXY_RUN_MARKER"),
        compression_mode=compression_mode,
    )

    home = managed_home()
    native_home = Path(
        os.environ.get("CLAUDE_LITELLM_NATIVE_HOME", default_native_home())
    ).expanduser()
    home.mkdir(parents=True, exist_ok=True)
    remove_stale_managed_config(home)
    if truthy_env("CLAUDE_LITELLM_LINK_NATIVE_STATE", True):
        sync_native_state(
            native_home=native_home,
            managed_home=home,
            excluded_names={
                "cache",
                "config.json",
                "mcp.json",
                "settings.json",
                "settings.local.json",
                PREFERENCES_FILE_NAME,
            },
            excluded_globs=("settings*.json*", "*.config.*"),
            backup_tag=LOCAL_BACKUP_TAG,
        )
    preferences = resolved_preferences(
        argv, load_preferences(home), dotenv_keys=dotenv_keys
    )
    write_preferences(home, preferences)
    write_managed_top_level_config(home, preferences=preferences)
    os.environ["CLAUDE_CONFIG_DIR"] = str(home)
    if truthy_env("CLAUDE_LITELLM_ISOLATE_HOME", True):
        os.environ["HOME"] = str(home)

    mcp_config = None
    if analytics_mcp_url is not None:
        mcp_config = home / "mcp.json"
        write_mcp_config(mcp_config, analytics_mcp_url=analytics_mcp_url)

    executable = real_claude()
    os.execvpe(
        executable,
        [
            executable,
            *default_extra_args(argv, mcp_config=mcp_config, preferences=preferences),
            *argv,
        ],
        os.environ.copy(),
    )
    return 127


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
