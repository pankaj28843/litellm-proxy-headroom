# Copy this file to .env and replace the placeholder values.

PHOENIX_DB_PASSWORD=phoenix
PHOENIX_DEFAULT_RETENTION_POLICY_DAYS=90
PHOENIX_PROJECT_NAME=litellm-proxy-headroom

ANALYTICS_POSTGRES_DB=analytics
ANALYTICS_POSTGRES_USER=analytics
ANALYTICS_POSTGRES_PASSWORD=analytics
ANALYTICS_POSTGRES_PORT=55432
ANALYTICS_DATABASE_URL=postgresql+asyncpg://analytics:analytics@127.0.0.1:55432/analytics
ANALYTICS_BACKEND_PORT=8010
ANALYTICS_CACHED_INPUT_COST_MULTIPLIER=0.10

# Host-side analytics URL for local scripts and non-Compose LiteLLM runs.
# Compose injects http://analytics-backend:8010 into the litellm container.
HEADROOM_ANALYTICS_URL=http://127.0.0.1:8010
HEADROOM_ANALYTICS_TIMEOUT_SECONDS=0.75

# Headroom compressed-context retrieval backend. This keeps Headroom as a
# library integration and stores/retrieves chunks through the custom backend.
HEADROOM_CCR_BACKEND=analytics-postgres
HEADROOM_CCR_ANALYTICS_TIMEOUT_SECONDS=0.75
HEADROOM_CCR_LOCAL_CACHE_ENTRIES=1000
HEADROOM_CCR_TENANT_PREFIX=
HEADROOM_SAVINGS_PROFILE=agent-90

# LiteLLM callback analytics buffering. These settings are intentionally
# bounded so analytics cannot create an unbounded in-memory queue.
HEADROOM_ANALYTICS_BUFFER_SIZE=1000
HEADROOM_ANALYTICS_BUFFER_WORKERS=2
HEADROOM_ANALYTICS_MAX_ATTEMPTS=3
HEADROOM_ANALYTICS_RETRY_BASE_SECONDS=0.1
HEADROOM_ANALYTICS_RETRY_MAX_SECONDS=1.0
HEADROOM_ANALYTICS_SHUTDOWN_TIMEOUT_SECONDS=2.0
HEADROOM_ANALYTICS_PENDING_LIMIT=1000

# Backend OpenTelemetry. Prompt, response, original chunk, and compressed chunk
# content must stay out of telemetry unless explicitly opted in elsewhere.
HEADROOM_ANALYTICS_OTEL_ENABLED=true
HEADROOM_ANALYTICS_OTEL_CONSOLE=false
HEADROOM_ANALYTICS_OTEL_METRIC_EXPORT_INTERVAL_MS=60000

LITELLM_MASTER_KEY=sk-local-dev
CHATGPT_AUTH_FILE=codex-chatgpt-auth.json
# Optional override. Compose defaults this to a single space so LiteLLM's
# ChatGPT provider does not prepend its bundled Codex instructions to Codex
# CLI requests that already carry their own instructions.
# CHATGPT_DEFAULT_INSTRUCTIONS=

# Host-side LiteLLM base URL for bin/codex-litellm and local A/B harness runs.
CODEX_LITELLM_BASE_URL=http://127.0.0.1:4000
# Host-side analytics backend URL for bin/codex-litellm's local analytics MCP.
CODEX_LITELLM_ANALYTICS_URL=http://127.0.0.1:8010
# Host-side LiteLLM base URL for bin/claude-litellm.
CLAUDE_LITELLM_BASE_URL=http://127.0.0.1:4000
# Host-side analytics backend URL for bin/claude-litellm's local analytics MCP.
CLAUDE_LITELLM_ANALYTICS_URL=http://127.0.0.1:8010
# Host-side LiteLLM base URL for bin/opencode-litellm.
OPENCODE_LITELLM_BASE_URL=http://127.0.0.1:4000
# Host-side analytics backend URL for bin/opencode-litellm's local analytics MCP.
OPENCODE_LITELLM_ANALYTICS_URL=http://127.0.0.1:8010
# Host-side LiteLLM base URL for bin/copilot-litellm's BYOK provider.
COPILOT_LITELLM_BASE_URL=http://127.0.0.1:4000
# Provider wire model used for Copilot CLI inference through LiteLLM.
COPILOT_LITELLM_MODEL=gpt-5.5
# Host-side LiteLLM base URL for bin/pi-litellm's custom provider.
PI_LITELLM_BASE_URL=http://127.0.0.1:4000
# Primary model used by bin/pi-litellm.
PI_LITELLM_MODEL=gpt-5.5

WEBUI_SECRET_KEY=change-me
WEBUI_ADMIN_NAME=Admin
WEBUI_ADMIN_EMAIL=admin@example.local
WEBUI_ADMIN_PASSWORD=change-me
