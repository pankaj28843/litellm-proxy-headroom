#!/usr/bin/env python3
from __future__ import annotations

import json
import os
import re
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parents[1]
SRC_ROOT = REPO_ROOT / "src"
if SRC_ROOT.exists():
    sys.path.insert(0, str(SRC_ROOT))

from litellm_proxy_headroom.agent_cli.managed_home import (  # noqa: E402
    PREFERENCES_FILE_NAME,
    compression_mode_header_value,
    default_home_path,
    find_real_executable,
    load_dotenv,
    load_preferences,
    normalize_base_url,
    option_value,
    preference_value,
    project_name_from_cwd,
    sync_native_state,
    truthy_env,
    write_preferences,
)

MANAGED_HOME_NAME = ".opencode-headroom"
LOCAL_BACKUP_TAG = "opencode-headroom-local-backup"
PROVIDER_ID = "litellm"
MODEL_RE = re.compile(r"^[A-Za-z0-9_.:/-]+$")
VARIANT_VALUES = {"low", "medium", "high", "xhigh", "max", "minimal"}
NO_MODEL_COMMANDS = {
    "acp",
    "agent",
    "attach",
    "auth",
    "completion",
    "debug",
    "export",
    "github",
    "help",
    "import",
    "mcp",
    "models",
    "pr",
    "serve",
    "session",
    "stats",
    "uninstall",
    "upgrade",
    "web",
}


def die(message: str, code: int = 1) -> None:
    print(f"opencode-litellm: {message}", file=sys.stderr)
    raise SystemExit(code)


def needs_api_key(argv: list[str]) -> bool:
    return not any(
        arg in {"-h", "--help", "help", "-v", "--version", "completion"} for arg in argv
    )


def validate_model(model: str, *, env_name: str) -> str:
    if not model or not MODEL_RE.match(model):
        die(f"{env_name} contains unsupported characters.")
    return model


def default_managed_home() -> Path:
    return default_home_path(
        MANAGED_HOME_NAME,
        fallback=REPO_ROOT / "tmp" / "opencode-headroom-home",
    )


def managed_home() -> Path:
    raw = os.environ.get("OPENCODE_LITELLM_HOME")
    if raw:
        return Path(raw).expanduser()
    return default_managed_home()


def has_model_arg(argv: list[str]) -> bool:
    return option_value(argv, "-m", "--model") is not None


def has_variant_arg(argv: list[str]) -> bool:
    return option_value(argv, "--variant") is not None


def model_from_arg(argv: list[str]) -> str | None:
    value = option_value(argv, "-m", "--model")
    if not value:
        return None
    if value.startswith(f"{PROVIDER_ID}/"):
        return value.split("/", 1)[1]
    return value


def first_command_index(argv: list[str]) -> int | None:
    options_with_values = {"-m", "--model", "--variant"}
    skip_next = False
    for index, arg in enumerate(argv):
        if skip_next:
            skip_next = False
            continue
        if arg in options_with_values:
            skip_next = True
            continue
        if arg.startswith("-"):
            continue
        return index
    return None


def should_add_model_arg(argv: list[str]) -> bool:
    if has_model_arg(argv):
        return False
    command_index = first_command_index(argv)
    first_command = "" if command_index is None else argv[command_index]
    return first_command not in NO_MODEL_COMMANDS


def add_run_variant_arg(argv: list[str], *, variant: str) -> list[str]:
    if not variant or has_variant_arg(argv):
        return argv
    command_index = first_command_index(argv)
    if command_index is None or argv[command_index] != "run":
        return argv
    result = list(argv)
    result.insert(command_index + 1, "--variant")
    result.insert(command_index + 2, variant)
    return result


def default_native_xdg_path(kind: str) -> Path:
    home = Path(os.environ.get("HOME", str(REPO_ROOT / "tmp"))).expanduser()
    if kind == "config":
        base = Path(os.environ.get("XDG_CONFIG_HOME", home / ".config")).expanduser()
    elif kind == "data":
        base = Path(
            os.environ.get("XDG_DATA_HOME", home / ".local" / "share")
        ).expanduser()
    elif kind == "cache":
        base = Path(os.environ.get("XDG_CACHE_HOME", home / ".cache")).expanduser()
    else:
        raise ValueError(kind)
    return base / "opencode"


def sync_native_xdg_state(
    *, config_home: Path, data_home: Path, cache_home: Path
) -> None:
    targets = (
        (default_native_xdg_path("data"), data_home / "opencode"),
        (default_native_xdg_path("cache"), cache_home / "opencode"),
    )
    for native_home, managed in targets:
        if native_home.exists():
            managed.mkdir(parents=True, exist_ok=True)
            sync_native_state(
                native_home=native_home,
                managed_home=managed,
                excluded_names={
                    "opencode.json",
                    "settings.json",
                    PREFERENCES_FILE_NAME,
                },
                excluded_globs=("*.config.*", "settings*.json"),
                backup_tag=LOCAL_BACKUP_TAG,
            )


def resolved_preferences(
    argv: list[str], preferences: dict[str, str], *, dotenv_keys: set[str]
) -> dict[str, str]:
    model = validate_model(
        preference_value(
            cli_value=model_from_arg(argv),
            env_name="OPENCODE_LITELLM_MODEL",
            preference_key="model",
            preferences=preferences,
            dotenv_keys=dotenv_keys,
            default="gpt-5.5",
        ),
        env_name="OPENCODE_LITELLM_MODEL",
    )
    small_model = validate_model(
        preference_value(
            env_name="OPENCODE_LITELLM_SMALL_MODEL",
            preference_key="small_model",
            preferences=preferences,
            dotenv_keys=dotenv_keys,
            default="gpt-5.5",
        ),
        env_name="OPENCODE_LITELLM_SMALL_MODEL",
    )
    variant = preference_value(
        cli_value=option_value(argv, "--variant"),
        env_name="OPENCODE_LITELLM_VARIANT",
        preference_key="variant",
        preferences=preferences,
        dotenv_keys=dotenv_keys,
        default="xhigh",
    )
    if variant not in VARIANT_VALUES:
        die(
            "OPENCODE_LITELLM_VARIANT must be one of low, medium, high, xhigh, max, or minimal."
        )
    return {
        **preferences,
        "model": model,
        "small_model": small_model,
        "variant": variant,
    }


def model_config(
    model: str,
    small_model: str,
    *,
    base_url: str,
    analytics_url: str | None,
    compression_mode: str | None,
) -> dict[str, object]:
    models: dict[str, object] = {
        model: {"name": model},
    }
    if small_model != model:
        models[small_model] = {"name": small_model}
    headers = {
        "X-LLM-Proxy-Client": "{env:OPENCODE_LITELLM_CLIENT}",
        "X-LLM-Proxy-Project": "{env:OPENCODE_LITELLM_PROJECT}",
        "X-LLM-Proxy-Run": "{env:LITELLM_PROXY_RUN_MARKER}",
    }
    if compression_mode:
        headers["X-LLM-Proxy-Compression"] = "{env:OPENCODE_LITELLM_COMPRESSION_MODE}"
    config: dict[str, object] = {
        "$schema": "https://opencode.ai/config.json",
        "autoupdate": False,
        "model": f"{PROVIDER_ID}/{model}",
        "small_model": f"{PROVIDER_ID}/{small_model}",
        "enabled_providers": [PROVIDER_ID],
        "provider": {
            PROVIDER_ID: {
                "npm": "@ai-sdk/openai-compatible",
                "name": "Local LiteLLM",
                "options": {
                    "baseURL": base_url,
                    "apiKey": "{env:LITELLM_MASTER_KEY}",
                    "headers": headers,
                },
                "models": models,
            }
        },
    }
    if analytics_url is not None:
        config["mcp"] = {
            "analytics": {
                "type": "remote",
                "url": analytics_url,
                "enabled": True,
                "oauth": False,
            }
        }
    return config


def write_config(path: Path, data: dict[str, object]) -> None:
    path.write_text(
        json.dumps(data, indent=2, sort_keys=True) + "\n",
        encoding="utf-8",
    )


def real_opencode() -> str:
    try:
        return find_real_executable(
            binary_name="opencode",
            wrapper_path=Path(__file__),
        )
    except FileNotFoundError:
        die(
            "could not find an opencode binary on PATH other than this wrapper.",
            code=127,
        )


def main(argv: list[str]) -> int:
    dotenv_keys = load_dotenv(REPO_ROOT / ".env")

    if not os.environ.get("LITELLM_MASTER_KEY") and needs_api_key(argv):
        die(
            f"LITELLM_MASTER_KEY is not set; add it to {REPO_ROOT / '.env'} or the environment."
        )

    try:
        litellm_base_url = normalize_base_url(
            os.environ.get("OPENCODE_LITELLM_BASE_URL", "http://10.20.30.1:24040"),
            env_name="OPENCODE_LITELLM_BASE_URL",
            suffix="/v1",
        )
        analytics_mcp_url = (
            None
            if truthy_env("OPENCODE_LITELLM_DISABLE_ANALYTICS_MCP", False)
            else normalize_base_url(
                os.environ.get(
                    "OPENCODE_LITELLM_ANALYTICS_URL", "http://127.0.0.1:28010"
                ),
                env_name="OPENCODE_LITELLM_ANALYTICS_URL",
                suffix="/mcp",
            )
        )
    except ValueError as exc:
        die(str(exc))
    try:
        compression_mode = compression_mode_header_value(
            os.environ.get("OPENCODE_LITELLM_COMPRESSION_MODE"),
            env_name="OPENCODE_LITELLM_COMPRESSION_MODE",
        )
    except ValueError as exc:
        die(str(exc))
    if compression_mode is None:
        os.environ.pop("OPENCODE_LITELLM_COMPRESSION_MODE", None)
    else:
        os.environ["OPENCODE_LITELLM_COMPRESSION_MODE"] = compression_mode

    home = managed_home()
    home.mkdir(parents=True, exist_ok=True)
    preferences = resolved_preferences(
        argv, load_preferences(home), dotenv_keys=dotenv_keys
    )
    write_preferences(home, preferences)
    model = preferences["model"]
    small_model = preferences["small_model"]
    variant = preferences["variant"]
    config_dir = home / "config-dir"
    xdg_config_home = home / "xdg-config"
    xdg_data_home = home / "xdg-data"
    xdg_cache_home = home / "xdg-cache"
    for path in (config_dir, xdg_config_home, xdg_data_home, xdg_cache_home):
        path.mkdir(parents=True, exist_ok=True)
    if truthy_env("OPENCODE_LITELLM_LINK_NATIVE_STATE", True):
        sync_native_xdg_state(
            config_home=xdg_config_home,
            data_home=xdg_data_home,
            cache_home=xdg_cache_home,
        )

    config_path = home / "opencode.json"
    write_config(
        config_path,
        model_config(
            model,
            small_model,
            base_url=litellm_base_url,
            analytics_url=analytics_mcp_url,
            compression_mode=compression_mode,
        ),
    )

    os.environ["OPENCODE_CONFIG"] = str(config_path)
    os.environ["OPENCODE_CONFIG_DIR"] = str(config_dir)
    os.environ["XDG_CONFIG_HOME"] = str(xdg_config_home)
    os.environ["XDG_DATA_HOME"] = str(xdg_data_home)
    os.environ["XDG_CACHE_HOME"] = str(xdg_cache_home)
    os.environ.setdefault("OPENCODE_LITELLM_CLIENT", "opencode")
    if "OPENCODE_LITELLM_PROJECT" not in os.environ:
        project = project_name_from_cwd()
        if project:
            os.environ["OPENCODE_LITELLM_PROJECT"] = project

    executable = real_opencode()
    extra_args = (
        ["--model", f"{PROVIDER_ID}/{model}"] if should_add_model_arg(argv) else []
    )
    os.execvpe(
        executable,
        [executable, *extra_args, *add_run_variant_arg(argv, variant=variant)],
        os.environ.copy(),
    )
    return 127


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
