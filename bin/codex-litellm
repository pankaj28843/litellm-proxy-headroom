#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
repo_root="$(cd -- "${script_dir}/.." && pwd -P)"
env_file="${repo_root}/.env"

if [[ -f "${env_file}" ]]; then
  set -a
  # shellcheck disable=SC1090
  . "${env_file}"
  set +a
fi

needs_key=1
for arg in "$@"; do
  case "${arg}" in
    -h|--help|help|-V|--version|completion)
      needs_key=0
      ;;
  esac
done

if [[ -n "${LITELLM_MASTER_KEY:-}" ]]; then
  export OPENAI_API_KEY="${LITELLM_MASTER_KEY}"
elif [[ "${needs_key}" -eq 1 ]]; then
  printf 'codex-litellm: LITELLM_MASTER_KEY is not set; add it to %s or the environment.\n' "${env_file}" >&2
  exit 1
fi

codex_home="${CODEX_LITELLM_HOME:-${repo_root}/tmp/codex-litellm-home}"
profile_name="litellm"
mkdir -p "${codex_home}"

cat > "${codex_home}/config.toml" <<'TOML'
# Generated by bin/codex-litellm. Keep this file free of secrets.

[mcp_servers.analytics]
url = "http://127.0.0.1:8010/mcp/"
enabled = true
TOML

cat > "${codex_home}/${profile_name}.config.toml" <<'TOML'
# Generated by bin/codex-litellm. Keep this file free of secrets.
model = "gpt-5.4-mini"
model_provider = "litellm"

[model_providers.litellm]
name = "Local LiteLLM"
base_url = "http://127.0.0.1:4000/v1"
env_key = "OPENAI_API_KEY"
wire_api = "responses"
TOML

export CODEX_HOME="${codex_home}"

realpath_of() {
  python3 -c 'import os, sys; print(os.path.realpath(sys.argv[1]))' "$1"
}

self_real="$(realpath_of "${BASH_SOURCE[0]}")"
real_codex=""

while IFS= read -r candidate; do
  [[ -z "${candidate}" ]] && continue
  candidate_real="$(realpath_of "${candidate}")"
  if [[ "${candidate_real}" == "${self_real}" ]]; then
    continue
  fi
  real_codex="${candidate}"
  break
done < <(type -a -P codex 2>/dev/null | awk '!seen[$0]++')

if [[ -z "${real_codex}" ]]; then
  printf 'codex-litellm: could not find a codex binary on PATH other than this wrapper.\n' >&2
  exit 127
fi

has_profile=0
for arg in "$@"; do
  case "${arg}" in
    -p|--profile|--profile=*)
      has_profile=1
      ;;
  esac
done

if [[ "${has_profile}" -eq 1 ]]; then
  exec "${real_codex}" "$@"
fi

exec "${real_codex}" --profile "${profile_name}" "$@"
